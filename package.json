{
  "scripts": {
    "lint": "npx @biomejs/biome lint frontend/",
    "test": "bash scripts/run-playwright.sh test",
    "test:unit": "npx vitest run",
    "test:unit:coverage": "npx vitest run --coverage",
    "test:backend:smoke": "cd backend && python3 -m unittest test_backend_smoke.py -v",
    "test:all": "cd backend && (python -m unittest discover -p 'test*_route*.py' -v || python3 -m unittest discover -p 'test*_route*.py' -v) && cd .. && bash scripts/run-playwright.sh test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "vitest": "^4.1.2"
  }
}
