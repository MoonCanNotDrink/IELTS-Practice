# Copy this file to .env and fill in your API keys

# Google Gemini (for LLM scoring)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=25

# Local Whisper (faster-whisper) fallback for ASR
WHISPER_MODEL_PATH=whisper_base_model
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Azure Speech (for pronunciation assessment)
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=eastasia
PRONUNCIATION_TIMEOUT_SECONDS=15

# App settings
DEBUG=true
APP_NAME="IELTS Speaking Practice"
APP_BASE_URL=http://localhost:8000

# Paths (local development)
DB_PATH=data/ielts.db
RECORDINGS_DIR=data/recordings

# Database (leave empty to use local SQLite DB_PATH)
DATABASE_URL=

# Authentication (REQUIRED — no defaults)
JWT_SECRET=change-me-to-a-random-secure-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
INVITE_CODE=your-invite-code-here
PASSWORD_RESET_EXPIRE_MINUTES=15

# Transactional email for password reset
EMAIL_FROM=no-reply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true

# Recording limits
MAX_RECORDING_SECONDS=150
# ALLOWED_AUDIO_FORMATS can be a JSON-style list or comma-separated values
ALLOWED_AUDIO_FORMATS=["webm","wav","mp3","ogg"]

# CORS (comma-separated origins; empty = allow all in DEBUG, deny all in production)
# CORS_ORIGINS=["http://localhost:8000","https://your-domain.com"]

# Deployment helpers (used by scripts)
# PROJECT_ID=your-gcp-project-id
# REGION=your-gcp-region
# SERVICE_NAME=ielts-speaking
# PORT=8000
# PIP_INDEX_URL=
# PIP_TRUSTED_HOST=
